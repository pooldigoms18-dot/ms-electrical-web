# Producción
# ============================================================

# Generar una clave privada diferente en el servidor.
DJANGO_SECRET_KEY=

# Separar múltiples valores con comas.
DJANGO_ALLOWED_HOSTS=example.com,www.example.com

# Incluir https:// en cada origen.
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# URL pública definitiva.
DJANGO_SITE_URL=https://www.example.com