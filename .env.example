DJANGO_SECRET_KEY='colocar-una-clave-secreta'
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# Correo electrónico
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_HOST=
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_DEFAULT_FROM_EMAIL=MS Electrical <no-reply@example.com>
MS_ELECTRICAL_NOTIFICATION_EMAILS=correo@example.com
# URL principal del sitio
DJANGO_SITE_URL=https://www.example.com
# Google Search Console
GOOGLE_SITE_VERIFICATION=
# ============================================================
# Producción
# ============================================================
# ============================================================
# HTTPS
# ============================================================

# False únicamente durante la prueba inicial mediante IP.
# Cambiar a True al instalar el certificado HTTPS.
DJANGO_USE_HTTPS=True
# Generar una clave privada diferente en el servidor.
DJANGO_SECRET_KEY=

# Separar múltiples valores con comas.
DJANGO_ALLOWED_HOSTS=example.com,www.example.com

# Incluir https:// en cada origen.
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# URL pública definitiva.
DJANGO_SITE_URL=https://www.example.com
# ============================================================
# Seguridad y producción
# ============================================================

# Nivel de logs:
# DEBUG, INFO, WARNING, ERROR o CRITICAL
DJANGO_LOG_LEVEL=INFO

# HSTS inicial.
DJANGO_SECURE_HSTS_SECONDS=3600

# Activar solo después de verificar todos los subdominios.
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False

# No activar hasta decidir conscientemente usar HSTS preload.
DJANGO_SECURE_HSTS_PRELOAD=False

# Evita envíos consecutivos desde una misma sesión.
QUOTE_SUBMISSION_COOLDOWN_SECONDS=30