server {
    listen 80;
    listen [::]:80;

    server_name __SERVER_NAME__;

    # Cinco imágenes de hasta 8 MB más el resto
    # de los datos del formulario.
    client_max_body_size 50M;


    # ========================================================
    # Archivos estáticos versionados por Django
    # ========================================================

    location /static/ {
        alias __APP_ROOT__/staticfiles/;

        access_log off;

        expires 30d;

        add_header Cache-Control
            "public, max-age=2592000, immutable";
    }


    # ========================================================
    # Imágenes y archivos subidos
    # ========================================================

    location /media/ {
        alias __APP_ROOT__/media/;

        expires 7d;

        add_header Cache-Control
            "public, max-age=604800";
    }


    # ========================================================
    # Aplicación Django mediante Gunicorn
    # ========================================================

    location / {
        proxy_pass http://127.0.0.1:8001;

        proxy_set_header Host $host;

        proxy_set_header X-Real-IP $remote_addr;

        proxy_set_header X-Forwarded-For
            $proxy_add_x_forwarded_for;

        proxy_set_header X-Forwarded-Proto
            $scheme;

        proxy_connect_timeout 30s;

        proxy_read_timeout 60s;
    }
}